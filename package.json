{
  "name": "codex-pet-director",
  "version": "0.5.5",
  "description": "Install the Codex Pet Director skill with /create-pet and checked hatch-pet handoff.",
  "author": "zixuanzhou0-ai",
  "license": "MIT",
  "homepage": "https://github.com/zixuanzhou0-ai/codex-pet-director#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zixuanzhou0-ai/codex-pet-director.git"
  },
  "bin": {
    "codex-pet-director": "bin/install.js",
    "codex-pet-director-install": "bin/install.js"
  },
  "scripts": {
    "validate": "node scripts/validate_repository.js",
    "test:install": "node scripts/test_install.js",
    "test": "npm run validate && npm run test:install && npm pack --dry-run"
  },
  "files": [
    "bin/install.js",
    ".codex-plugin/plugin.json",
    "assets/**/*",
    "commands/**/*",
    "codex-pet-director/**/*",
    "!codex-pet-director/**/__pycache__/**",
    "!codex-pet-director/**/*.pyc",
    "skills/**/*",
    "!skills/**/__pycache__/**",
    "!skills/**/*.pyc",
    "examples/**/*",
    "install.cmd",
    "install-plugin.ps1",
    "install.ps1",
    "install.sh",
    "README.md",
    "docs/**/*",
    "scripts/**/*"
  ],
  "keywords": [
    "codex",
    "skill",
    "desktop-pet",
    "pet"
  ]
}
